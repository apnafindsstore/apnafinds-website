PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Local admin login. Change all four values before public hosting.
ADMIN_NAME=ApnaFinds Administrator
ADMIN_EMAIL=admin@apnafinds.local
ADMIN_PASSWORD=ApnaFinds@123
ADMIN_SESSION_SECRET=change-this-long-session-secret-before-hosting
ADMIN_API_TOKEN=apnafinds-local-admin-token
ADMIN_SESSION_HOURS=8
ADMIN_REMEMBER_DAYS=30

# Automatic order and logistics process.
LOGISTICS_MODE=demo
AUTO_BOOK_SHIPMENTS=true
AUTOMATION_INTERVAL_SECONDS=20
DEMO_ORDER_STAGE_SECONDS=45
DEMO_RETURN_STAGE_SECONDS=60

# Add real Shiprocket credentials only after KYC and pickup setup.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_POSTCODE=
SHIPROCKET_COURIER_ID=

DEFAULT_PACKAGE_LENGTH_CM=20
DEFAULT_PACKAGE_BREADTH_CM=15
DEFAULT_PACKAGE_HEIGHT_CM=10
DEFAULT_PACKAGE_WEIGHT_KG=0.5

TEAM_WEBHOOK_URL=
LOGISTICS_WEBHOOK_SECRET=change-this-webhook-secret

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
