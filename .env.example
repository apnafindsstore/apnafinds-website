PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# Local admin login. Change all four values before public hosting.
ADMIN_NAME=ApnaFinds Administrator
ADMIN_EMAIL=admin@apnafinds.local
ADMIN_PASSWORD=ApnaFinds@123
ADMIN_SESSION_SECRET=change-this-long-session-secret-before-hosting
ADMIN_API_TOKEN=apnafinds-local-admin-token
ADMIN_SESSION_HOURS=8
ADMIN_REMEMBER_DAYS=30

# Automatic order and logistics process.
LOGISTICS_MODE=demo
AUTO_BOOK_SHIPMENTS=true
AUTOMATION_INTERVAL_SECONDS=20
DEMO_ORDER_STAGE_SECONDS=45
DEMO_RETURN_STAGE_SECONDS=60

# Add real Shiprocket credentials only after KYC and pickup setup.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_POSTCODE=
SHIPROCKET_COURIER_ID=

DEFAULT_PACKAGE_LENGTH_CM=20
DEFAULT_PACKAGE_BREADTH_CM=15
DEFAULT_PACKAGE_HEIGHT_CM=10
DEFAULT_PACKAGE_WEIGHT_KG=0.5

TEAM_WEBHOOK_URL=
LOGISTICS_WEBHOOK_SECRET=change-this-webhook-secret

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# Seller profile and COD advance-payment configuration.
SELLER_NAME=ApnaFinds Seller
SELLER_STORE_NAME=ApnaFinds
SELLER_SUPPORT_EMAIL=support@apnafinds.com
SELLER_SUPPORT_PHONE=9666337370
SELLER_UPI_ID=apnafinds@upi

# COD customers must pay an online advance before shipment booking.
# The amount must stay between INR 10 and INR 49.
COD_ADVANCE_ENABLED=true
COD_ADVANCE_AMOUNT=49
COD_ADVANCE_MIN=10
COD_ADVANCE_MAX=49

# demo = automatic local test payment
# manual = customer UTR/reference requires admin verification
# live = connect a real payment gateway before use
COD_ADVANCE_MODE=demo


# CUSTOMER AUTHENTICATION
CUSTOMER_SESSION_SECRET=replace-with-a-long-random-customer-secret
CUSTOMER_SESSION_HOURS=12
CUSTOMER_REMEMBER_DAYS=30

# OTP
# demo: displays/logs OTP for testing only.
# production: email OTP uses SMTP; phone OTP sends to OTP_SMS_WEBHOOK_URL.
OTP_MODE=demo
OTP_DEMO_EXPOSE=true
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_SECONDS=30

# EMAIL OTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ApnaFinds <support@apnafinds.com>

# PHONE OTP PROVIDER ADAPTER
# Your SMS provider/automation endpoint must accept:
# { phone: "91XXXXXXXXXX", otp: "123456", purpose: "...", brand: "ApnaFinds" }
OTP_SMS_WEBHOOK_URL=
OTP_SMS_WEBHOOK_TOKEN=
